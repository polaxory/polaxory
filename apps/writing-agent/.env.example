# Copy to .env and fill in. .env is gitignored.

# ── Required for generate.ts (the main WritingAgent service) ───────────────

# Anthropic API key. Get from console.anthropic.com.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional config ────────────────────────────────────────────────────────

# Where constitution docs live. Defaults to parent of agent/.
POLAXORY_DIR=/Users/blake.jaraczeski/polaxory

# Model overrides for generate.ts. Defaults are sane.
GENERATION_MODEL=claude-sonnet-4-5
SECURITY_GATE_MODEL=claude-haiku-4-5

# Max tokens for any single generation output.
MAX_OUTPUT_TOKENS=2048

# ── Cheap LLM providers for compare.ts (Task #16) ──────────────────────────
#
# Each provider profile only activates if its API key is set. Skip the ones
# you don't want to test. See src/providers.ts for the registered profile list.

# Groq — fastest cheap option (~$0.06/M tokens). console.groq.com
GROQ_API_KEY=

# Mistral — strong reasoning at moderate cost. console.mistral.ai
MISTRAL_API_KEY=

# DeepSeek — V3 / R1, cheap with strong reasoning. platform.deepseek.com
DEEPSEEK_API_KEY=

# Gemini via Google AI Studio (OpenAI-compatible endpoint). aistudio.google.com
GEMINI_API_KEY=
