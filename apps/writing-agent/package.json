{
  "name": "polaxory-writing-agent",
  "version": "0.1.0",
  "description": "WritingAgent surface for Polaxory. Loads constitution docs, generates output in character via Claude, validates through security gate, logs to disk.",
  "type": "module",
  "scripts": {
    "generate": "tsx src/generate.ts",
    "compare": "tsx src/compare.ts",
    "build": "tsc",
    "start": "node dist/generate.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5",
    "openai": "^4.65.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
