# Copy to .env and fill in. .env is gitignored.

# Required: API key from a Polaxory Roblox Creator Hub account.
# Generate at https://create.roblox.com/dashboard/credentials
# Required permissions: universe-places:write on the test universe/place.
ROBLOX_API_KEY=your-roblox-api-key-here

# Required: a placeholder Universe ID, created manually in Creator Hub.
# Find it in the experience URL or via the Open Cloud experiences endpoint.
ROBLOX_UNIVERSE_ID=

# Required: a placeholder Place ID inside the above universe.
# Each universe has one start place by default; that ID is fine for validation.
ROBLOX_PLACE_ID=

# Optional: path to the .rbxlx fixture to upload. Defaults to fixtures/minimal.rbxlx.
ROBLOX_TEST_RBXLX=

# Optional: 'Saved' (default, safe, doesn't go live) or 'Published' (goes live).
# Keep on Saved for end-to-end validation. Use Published only when actually shipping a wave.
ROBLOX_VERSION_TYPE=Saved
