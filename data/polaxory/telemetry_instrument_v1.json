{
  "instrumentVersion": "polaxory.telemetry.instrument.v1",
  "primaryQuestion": "Does claiming a round-completion reward increase the chance that a player starts another round?",
  "eventSpine": [
    "round_started",
    "round_completed",
    "reward_granted",
    "reward_claimed",
    "next_round_started"
  ],
  "events": {
    "round_started": {
      "required": ["sessionId", "roundId", "startedAtUnixMs"]
    },
    "round_completed": {
      "required": ["sessionId", "roundId", "completedAtUnixMs", "durationMs", "outcome"],
      "allowedOutcomeValues": ["success", "fail", "abandon", "timeout"]
    },
    "reward_granted": {
      "required": ["sessionId", "roundId", "rewardId", "rewardType", "amount"]
    },
    "reward_claimed": {
      "required": ["sessionId", "roundId", "rewardId", "claimedAtUnixMs"]
    },
    "next_round_started": {
      "required": ["sessionId", "previousRoundId", "roundId", "startedAtUnixMs", "source"],
      "allowedSourceValues": ["reward_claim_panel", "play_again_button", "auto_queue", "manual_start"]
    }
  },
  "minimumAggregates": [
    "rounds_started",
    "rounds_completed",
    "rewards_granted",
    "rewards_claimed",
    "next_rounds_started",
    "completion_rate",
    "reward_claim_rate",
    "next_round_rate_after_claim",
    "avg_round_duration_ms",
    "median_round_duration_ms"
  ],
  "privacyBoundary": {
    "containsRawRobloxUserIds": false,
    "containsPlayerNames": false,
    "containsChatText": false,
    "containsIpAddresses": false,
    "containsDeviceIds": false,
    "committedSnapshotsAreAggregateOnly": true
  },
  "decisionThresholds": {
    "completion_rate_below_0_35": "Fix round clarity before reward design.",
    "reward_claim_rate_below_0_50": "Fix reward presentation before economy depth.",
    "next_round_rate_after_claim_below_0_25": "Reward is not yet creating replay intent."
  }
}
